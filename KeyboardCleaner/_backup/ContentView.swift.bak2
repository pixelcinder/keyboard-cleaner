    let title: String
    let subtitle: String

    var body: some View {
        HStack(spacing: 14) {
            ZStack {
                RoundedRectangle(cornerRadius: 9)
                    .fill(.ultraThinMaterial)
                    .frame(width: 38, height: 38)
                    .overlay(RoundedRectangle(cornerRadius: 9)
                        .stroke(.white.opacity(0.18), lineWidth: 0.5))
                Image(systemName: icon)
                    .font(.system(size: 16, weight: .medium))
                    .foregroundStyle(.white.opacity(0.82))
                    .accessibilityHidden(true)
            }

            VStack(alignment: .leading, spacing: 2) {
                Text(title)
                    .font(.system(size: 13, weight: .semibold, design: .rounded))
                    .foregroundStyle(.white.opacity(0.9))
                Text(subtitle)
                    .font(.system(size: 11, weight: .regular))
                    .foregroundStyle(.white.opacity(0.45))
            }

            Spacer()
        }
        .padding(.horizontal, 14)
        .padding(.vertical, 10)
        .background(
            RoundedRectangle(cornerRadius: 13)
                .fill(.ultraThinMaterial)
                .overlay(RoundedRectangle(cornerRadius: 13)
                    .stroke(.white.opacity(0.12), lineWidth: 0.5))
        )
        .accessibilityElement(children: .combine)
        .accessibilityLabel("\(title). \(subtitle)")
    }
}

// MARK: - Locked View (in-app, visible behind the overlay when app is in focus)

struct LockedView: View {
    @ObservedObject var cleaningState: CleaningStateManager
    @State private var pulseAnimation = false
    @State private var errorShake = false

    var body: some View {
        VStack(spacing: 0) {
            if cleaningState.accessibilityDenied {
                AccessibilityWarningBanner()
                    .padding(.horizontal, 24)
                    .padding(.top, 20)
                    .transition(.move(edge: .top).combined(with: .opacity))
            }

            Spacer()

            VStack(spacing: 22) {
                // Pulsing lock orb
                ZStack {
                    PulseRings(animating: pulseAnimation, count: 3,
                               baseSize: 130, step: 34, maxOpacity: 0.07)

                    GlassCircle(diameter: 114) {
                        Image(systemName: "lock.fill")
                            .font(.system(size: 42, weight: .light))
                            .foregroundStyle(.white.opacity(0.88))
                            .accessibilityHidden(true)
                    }
                }
                .offset(x: errorShake ? -8 : 0)
                .animation(
                    errorShake
                        ? .easeInOut(duration: Timing.errorShakeUnit)
                            .repeatCount(Timing.errorShakeRepeat, autoreverses: true)
                        : .default,
                    value: errorShake
                )
                .onAppear { pulseAnimation = true }
                .accessibilityLabel("Keyboard is locked")

                VStack(spacing: 6) {
                    Text("Keyboard Locked")
                        .font(.system(size: 24, weight: .bold, design: .rounded))
                        .foregroundStyle(.white)
                        .accessibilityAddTraits(.isHeader)

                    Text(statusMessage)
                        .font(.system(size: 13, weight: .regular))
                        .foregroundStyle(.white.opacity(0.55))
                        .multilineTextAlignment(.center)
                        .frame(maxWidth: 260)
                        .animation(.easeInOut(duration: 0.2), value: cleaningState.authState)

                    if cleaningState.authState == .idle || cleaningState.authState == .failed {
                        TimerDisplay(cleaningState: cleaningState)
                            .padding(.top, 4)
                    }
                }
            }

            Spacer()

            // Touch ID button
            UnlockButton(cleaningState: cleaningState, onFailure: triggerErrorShake)
                .padding(.bottom, 44)
        }
        .frame(maxWidth: .infinity)
    }

    private var statusMessage: String {
        switch cleaningState.authState {
        case .idle:           return "All keystrokes are blocked.\nClean your keyboard freely."
        case .authenticating: return "Place your finger on Touch ID…"
        case .failed:         return "Touch ID failed. Try again."
        case .success:        return "Unlocked successfully!"
        }
    }

    private func triggerErrorShake() {
        errorShake = true
        DispatchQueue.main.asyncAfter(deadline: .now() + 0.4) { errorShake = false }
    }
}

// MARK: - Unlock Button (shared by LockedView and OverlayView)

struct UnlockButton: View {
    @ObservedObject var cleaningState: CleaningStateManager
    let onFailure: () -> Void

    var body: some View {
        Button {
            cleaningState.authenticateToUnlock { success in
                if !success { onFailure() }
            }
        } label: {
            VStack(spacing: 10) {
                ZStack {
                    // Soft color glow behind the circle
                    Circle()
                        .fill(stateColor.opacity(0.18))
                        .frame(width: 80, height: 80)
                        .blur(radius: 14)

                    GlassCircle(diameter: 62) {
                        Image(systemName: stateIcon)
                            .font(.system(size: 26, weight: .light))
                            .foregroundStyle(stateColor)
                            .accessibilityHidden(true)
                    }
                    .overlay(
                        // Color-tinted rim to reinforce state without relying on color alone
                        Circle()
                            .stroke(stateColor.opacity(0.55), lineWidth: 1)
                            .frame(width: 62, height: 62)
                    )
                }
                .scaleEffect(cleaningState.authState == .authenticating ? 1.06 : 1.0)
                .animation(
                    .easeInOut(duration: 0.8).repeatWhile(
                        cleaningState.authState == .authenticating, autoreverses: true),
                    value: cleaningState.authState
                )

                Text(stateLabel)
                    .font(.system(size: 13, weight: .medium, design: .rounded))
                    .foregroundStyle(.white.opacity(0.6))
            }
        }
        .buttonStyle(.plain)
        .disabled(cleaningState.authState == .authenticating || cleaningState.authState == .success)
        .accessibilityLabel(stateLabel)
        .accessibilityHint(stateHint)
    }

    private var stateIcon: String {
        switch cleaningState.authState {
        case .idle, .authenticating: return "touchid"
        case .failed:                return "arrow.clockwise"
        case .success:               return "checkmark.circle"
        }
    }

    private var stateLabel: String {
        switch cleaningState.authState {
        case .idle:           return "Unlock with Touch ID"
        case .authenticating: return "Verifying…"
        case .failed:         return "Try Again"
        case .success:        return "Unlocked"
        }
    }

    private var stateColor: Color {
        switch cleaningState.authState {
        case .failed:         return Color(red: 1.0, green: 0.42, blue: 0.42)
        case .authenticating: return Color(red: 0.55, green: 0.78, blue: 1.0)
        case .success:        return Color(red: 0.38, green: 0.88, blue: 0.6)
        default:              return .white
        }
    }

    // Hint varies by state so VoiceOver conveys context, not just button name
    private var stateHint: String {
        switch cleaningState.authState {
        case .idle:   return "Uses Touch ID or password to safely unlock the keyboard"
        case .failed: return "Previous attempt failed. Tap to try again."
        default:      return ""
        }
    }
}

// MARK: - Pulse Rings

struct PulseRings: View {
    let animating: Bool
    let count: Int
    let baseSize: CGFloat
    let step: CGFloat
    let maxOpacity: Double

    var body: some View {
        ZStack {
            ForEach(0..<count, id: \.self) { i in
                Circle()
                    .stroke(.white.opacity(max(0, maxOpacity - Double(i) * 0.02)), lineWidth: 1)
                    .frame(width: baseSize + CGFloat(i) * step,
                           height: baseSize + CGFloat(i) * step)
                    .scaleEffect(animating ? 1.07 : 1.0)
                    .animation(
                        .easeInOut(duration: Timing.pulse)
                            .repeatForever(autoreverses: true)
                            .delay(Double(i) * 0.32),
                        value: animating
                    )
            }
        }
        .accessibilityHidden(true)
    }
}

// MARK: - Glass Circle (reusable 3-D glass orb)

struct GlassCircle<Content: View>: View {
    let diameter: CGFloat
    let content: Content

    init(diameter: CGFloat, @ViewBuilder content: () -> Content) {
        self.diameter = diameter
        self.content = content()
    }

    var body: some View {
        ZStack {
            // Depth shadow — offset downward to suggest light from above
            Circle()
                .fill(Color.black.opacity(0.22))
                .frame(width: diameter, height: diameter)
                .blur(radius: diameter * 0.20)
                .offset(y: diameter * 0.09)

            // Glass body
            Circle()
                .fill(.ultraThinMaterial)
                .frame(width: diameter, height: diameter)
                // Top-left specular highlight (simulates light from upper-left)
                .overlay(
                    Circle()
                        .fill(LinearGradient(
                            colors: [.white.opacity(0.22), .clear],
                            startPoint: UnitPoint(x: 0.2, y: 0.05),
                            endPoint: UnitPoint(x: 0.6, y: 0.55)
                        ))
                )
                // Rim — bright top-left, fading to subtle bottom-right
                .overlay(
                    Circle()
                        .stroke(LinearGradient(
                            colors: [.white.opacity(0.65), .white.opacity(0.06), .white.opacity(0.22)],
                            startPoint: .topLeading,
                            endPoint: .bottomTrailing
                        ), lineWidth: 1)
                )
                .shadow(color: .black.opacity(0.18), radius: diameter * 0.18, y: diameter * 0.06)

            content
        }
    }
}

// MARK: - Timer Display (compact, used in LockedView)

struct TimerDisplay: View {
    @ObservedObject var cleaningState: CleaningStateManager

    var body: some View {
        HStack(spacing: 14) {
            Label {
                Text(cleaningState.elapsedTimeString)
                    .font(.system(size: 12, weight: .medium).monospacedDigit())
                    .foregroundStyle(.white.opacity(0.45))
            } icon: {
                Image(systemName: "clock")
                    .font(.system(size: 10))
                    .foregroundStyle(.white.opacity(0.35))
                    .accessibilityHidden(true)
            }
            .accessibilityLabel("Locked for \(cleaningState.elapsedTimeString)")

            if let remaining = cleaningState.remainingTimeString {
                Label {
                    Text(remaining)
                        .font(.system(size: 12, weight: .medium).monospacedDigit())
                        .foregroundStyle(.white.opacity(0.45))
                } icon: {
                    Image(systemName: "timer")
                        .font(.system(size: 10))
                        .foregroundStyle(.white.opacity(0.35))
                        .accessibilityHidden(true)
                }
                .accessibilityLabel("Auto-unlock in \(remaining)")
            }
        }
    }
}

