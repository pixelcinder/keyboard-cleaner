import SwiftUI

// MARK: - Animation Constants

private enum Timing {
    static let pulse: Double = 2.8
    static let background: Double = 14.0
    static let errorShakeUnit: Double = 0.06
    static let errorShakeRepeat = 6
}

// MARK: - Root View

struct ContentView: View {
    @EnvironmentObject private var cleaningState: CleaningStateManager

    var body: some View {
        ZStack {
            AppBackgroundView()

            if cleaningState.isLocked {
                LockedView(cleaningState: cleaningState)
                    .transition(.asymmetric(
                        insertion: .scale(scale: 0.96).combined(with: .opacity),
                        removal:   .scale(scale: 1.04).combined(with: .opacity)
                    ))
            } else {
                IdleView(cleaningState: cleaningState)
                    .transition(.asymmetric(
                        insertion: .scale(scale: 0.96).combined(with: .opacity),
                        removal:   .scale(scale: 1.04).combined(with: .opacity)
                    ))
            }
        }
        .frame(width: 480, height: 560)
        .ignoresSafeArea()
        .animation(.spring(response: 0.45, dampingFraction: 0.82), value: cleaningState.isLocked)
    }
}

// MARK: - Idle / Home Screen

struct IdleView: View {
    @ObservedObject var cleaningState: CleaningStateManager

    var body: some View {
        VStack(spacing: 0) {
            Spacer()

            // Icon + title
            VStack(spacing: 14) {
                GlassCircle(diameter: 96) {
                    Image(systemName: "keyboard")
                        .font(.system(size: 38, weight: .light))
                        .foregroundStyle(.white.opacity(0.9))
                        .accessibilityHidden(true)
                }
                .accessibilityHidden(true)

                VStack(spacing: 5) {
                    Text("Keyboard Cleaner")
                        .font(.system(size: 26, weight: .bold, design: .rounded))
                        .foregroundStyle(.white)
                        .accessibilityAddTraits(.isHeader)

                    Text("Lock your keyboard to clean safely")
                        .font(.system(size: 14, weight: .regular))
                        .foregroundStyle(.white.opacity(0.55))
                }
            }
            .padding(.bottom, 28)

            // Accessibility permission card — shown until permission is granted
            if !cleaningState.isAccessibilityAuthorized {
                AccessibilityPermissionCard(cleaningState: cleaningState)
                    .padding(.horizontal, 32)
                    .padding(.bottom, 12)
                    .transition(.move(edge: .top).combined(with: .opacity))
            }

            // Info cards
            VStack(spacing: 8) {
                InfoCardRow(icon: "hand.raised.slash",
                            title: "Blocks all keystrokes",
                            subtitle: "No accidental input while cleaning")
                InfoCardRow(icon: "touchid",
                            title: "Touch ID to unlock",
                            subtitle: "Safe & secure, can't unlock by mistake")
                InfoCardRow(icon: "sparkles",
                            title: "Wipe with confidence",
                            subtitle: "Clean every key thoroughly")
            }
            .padding(.horizontal, 32)
            .padding(.bottom, 16)

            // Auto-unlock picker
            AutoUnlockPickerRow(cleaningState: cleaningState)
                .padding(.horizontal, 32)

            Spacer()

            // Lock button
            Button { cleaningState.startCleaning() } label: {
                HStack(spacing: 9) {
                    Image(systemName: "lock.fill")
                        .font(.system(size: 15, weight: .semibold))
                        .accessibilityHidden(true)
                    Text("Lock Keyboard")
                        .font(.system(size: 16, weight: .semibold, design: .rounded))
                }
                .foregroundStyle(.white)
                .frame(maxWidth: .infinity)
                .frame(height: 50)
                .background(GlassButtonBackground())
                .shadow(color: .black.opacity(0.18), radius: 10, y: 4)
            }
            .buttonStyle(.plain)
            .padding(.horizontal, 32)
            .accessibilityLabel("Lock keyboard for cleaning")
            .accessibilityHint(cleaningState.isAccessibilityAuthorized
                ? "Blocks all keyboard input. Use Touch ID to unlock when done."
                : "Keyboard input may not be blocked — Accessibility access not yet granted.")

            Text("Requires Touch ID to unlock")
                .font(.system(size: 11, weight: .regular))
                .foregroundStyle(.white.opacity(0.35))
                .padding(.top, 10)
                .padding(.bottom, 24)
        }
        .animation(.spring(response: 0.4, dampingFraction: 0.8),
                   value: cleaningState.isAccessibilityAuthorized)
    }
}

// MARK: - Accessibility Permission Card

struct AccessibilityPermissionCard: View {
    @ObservedObject var cleaningState: CleaningStateManager

    var body: some View {
        Button {
            cleaningState.requestAccessibilityPermission()
        } label: {
            HStack(spacing: 12) {
                Image(systemName: "lock.shield.fill")
                    .font(.system(size: 20, weight: .medium))
                    .foregroundStyle(.orange)
                    .accessibilityHidden(true)

                VStack(alignment: .leading, spacing: 3) {
                    Text("Accessibility Access Required")
                        .font(.system(size: 13, weight: .semibold, design: .rounded))
                        .foregroundStyle(.white.opacity(0.95))
                    Text("Needed to block keystrokes — tap to enable in System Settings")
                        .font(.system(size: 11, weight: .regular))
                        .foregroundStyle(.white.opacity(0.6))
                        .fixedSize(horizontal: false, vertical: true)
                }

                Spacer(minLength: 0)

                Image(systemName: "chevron.right")
                    .font(.system(size: 10, weight: .semibold))
                    .foregroundStyle(.white.opacity(0.35))
                    .accessibilityHidden(true)
            }
            .padding(.horizontal, 14)
            .padding(.vertical, 11)
            .background(
                RoundedRectangle(cornerRadius: 13)
                    .fill(Color.orange.opacity(0.12))
                    .overlay(RoundedRectangle(cornerRadius: 13)
                        .stroke(Color.orange.opacity(0.35), lineWidth: 0.5))
            )
        }
        .buttonStyle(.plain)
        .accessibilityLabel("Accessibility access required. Tap to open System Settings and enable keyboard blocking.")
        .accessibilityHint("Opens the system permission prompt")
    }
}

// MARK: - Auto-Unlock Picker Row

struct AutoUnlockPickerRow: View {
    @ObservedObject var cleaningState: CleaningStateManager

    var body: some View {
        HStack(spacing: 10) {
            Image(systemName: "timer")
                .font(.system(size: 13, weight: .medium))
                .foregroundStyle(.white.opacity(0.5))
                .accessibilityHidden(true)

            Text("Auto-unlock")
                .font(.system(size: 13, weight: .medium, design: .rounded))
                .foregroundStyle(.white.opacity(0.55))
                .accessibilityHidden(true) // label is on the Picker

            Spacer()

            Picker("Auto-unlock after", selection: $cleaningState.autoUnlockTimeout) {
                ForEach(AutoUnlockTimeout.allCases) { option in
                    Text(option.label).tag(option)
                }
            }
            .pickerStyle(.segmented)
            .frame(width: 210)
            .colorScheme(.dark)
            .accessibilityHint("Set a duration after which the keyboard unlocks automatically")
        }
    }
}

// MARK: - Info Card Row

struct InfoCardRow: View {
