// MARK: - Menu Bar View

struct MenuBarView: View {
    @EnvironmentObject var cleaningState: CleaningStateManager

    var body: some View {
        if cleaningState.isLocked {
            Text("Locked for \(cleaningState.elapsedTimeString)")
                .foregroundStyle(.secondary)
            if let remaining = cleaningState.remainingTimeString {
                Text("Auto-unlock in \(remaining)")
                    .foregroundStyle(.secondary)
            }
            Divider()
            Button("Unlock Keyboard…") { cleaningState.authenticateToUnlock { _ in } }
        } else {
            Button("Lock Keyboard") { cleaningState.startCleaning() }
        }
        Divider()
        Button("Quit Keyboard Cleaner") { NSApplication.shared.terminate(nil) }
    }
}

// MARK: - App Background (main window — soft dark navy, subtle aurora)

struct AppBackgroundView: View {
    @State private var phase: CGFloat = 0

    var body: some View {
        ZStack {
            // Softer base: dark navy, not near-black
            LinearGradient(
                colors: [
                    Color(red: 0.08, green: 0.09, blue: 0.18),
                    Color(red: 0.10, green: 0.11, blue: 0.22)
                ],
                startPoint: .topLeading, endPoint: .bottomTrailing
            )

            // Blue aurora — muted
            Ellipse()
                .fill(RadialGradient(
                    colors: [Color(red: 0.25, green: 0.40, blue: 0.85).opacity(0.22), .clear],
                    center: .center, startRadius: 0, endRadius: 190))
                .frame(width: 340, height: 240)
                .offset(x: -55 + sin(phase) * 18, y: -75 + cos(phase * 0.7) * 14)
                .blur(radius: 44)

            // Lavender aurora — muted
            Ellipse()
                .fill(RadialGradient(
                    colors: [Color(red: 0.45, green: 0.28, blue: 0.78).opacity(0.16), .clear],
                    center: .center, startRadius: 0, endRadius: 170))
                .frame(width: 280, height: 280)
                .offset(x: 75 + cos(phase * 0.8) * 22, y: 90 + sin(phase * 1.1) * 18)
                .blur(radius: 52)

            // Cyan accent — very subtle
            Ellipse()
                .fill(RadialGradient(
                    colors: [Color(red: 0.12, green: 0.65, blue: 0.80).opacity(0.10), .clear],
                    center: .center, startRadius: 0, endRadius: 130))
                .frame(width: 240, height: 180)
                .offset(x: 18 + sin(phase * 1.3) * 26, y: -110 + cos(phase * 0.9) * 22)
                .blur(radius: 38)
        }
        .ignoresSafeArea()
        .onAppear {
            withAnimation(.linear(duration: Timing.background).repeatForever(autoreverses: false)) {
                phase = .pi * 2
            }
        }
    }
}

// MARK: - Overlay Background (full-screen — blurs desktop, adds subtle tints)

struct OverlayBackgroundView: View {
    @State private var phase: CGFloat = 0

    var body: some View {
        ZStack {
            // Material base: blurs real desktop content behind the window
            Rectangle().fill(.regularMaterial)

            // Very subtle tinted aurora on top of the blur
            Ellipse()
                .fill(Color(red: 0.3, green: 0.55, blue: 1.0).opacity(0.10))
                .frame(width: 700, height: 500)
                .offset(x: -100 + sin(phase) * 35, y: -220 + cos(phase * 0.7) * 28)
                .blur(radius: 90)

            Ellipse()
                .fill(Color(red: 0.55, green: 0.30, blue: 0.90).opacity(0.08))
                .frame(width: 600, height: 550)
                .offset(x: 160 + cos(phase * 0.8) * 30, y: 160 + sin(phase * 1.1) * 25)
                .blur(radius: 100)
        }
        .ignoresSafeArea()
        .onAppear {
            withAnimation(.linear(duration: 18).repeatForever(autoreverses: false)) {
                phase = .pi * 2
            }
        }
    }
}

// MARK: - Overlay View (full-screen lock screen on every display)

struct OverlayView: View {
    @ObservedObject var cleaningState: CleaningStateManager
    @State private var pulseAnimation = false
    @State private var errorShake = false

    var body: some View {
        ZStack {
            OverlayBackgroundView()

            VStack(spacing: 0) {
                Spacer()

                // Lock orb
                ZStack {
                    PulseRings(animating: pulseAnimation, count: 3,
                               baseSize: 150, step: 46, maxOpacity: 0.06)

                    GlassCircle(diameter: 130) {
                        Image(systemName: "lock.fill")
                            .font(.system(size: 50, weight: .light))
                            .foregroundStyle(.white.opacity(0.88))
                            .accessibilityHidden(true)
                    }
                }
                .onAppear { pulseAnimation = true }
                .accessibilityLabel("Keyboard is locked")
                .padding(.bottom, 30)

                // Title block
                VStack(spacing: 8) {
                    Text("Keyboard Locked")
                        .font(.system(size: 34, weight: .bold, design: .rounded))
                        .foregroundStyle(.primary)
                        .accessibilityAddTraits(.isHeader)

                    Group {
                        if cleaningState.accessibilityDenied {
                            Text("Keystrokes may not be blocked — grant Accessibility access in System Settings")
                                .foregroundStyle(.orange)
                        } else {
                            Text("All keystrokes are blocked — clean your keyboard freely")
                                .foregroundStyle(.secondary)
                        }
                    }
                    .font(.system(size: 15, weight: .regular))
                    .multilineTextAlignment(.center)
                    .frame(maxWidth: 460)
                    .animation(.easeInOut(duration: 0.2), value: cleaningState.accessibilityDenied)
                }
                .padding(.bottom, 52)

                // Hero timer
                if cleaningState.autoUnlockTimeout != .never {
                    CountdownRingView(cleaningState: cleaningState)
                } else {
                    OverlayElapsedView(cleaningState: cleaningState)
                }

                Spacer()

                // Unlock button
                UnlockButton(cleaningState: cleaningState, onFailure: triggerErrorShake)
                    .offset(x: errorShake ? -8 : 0)
                    .animation(
                        errorShake
                            ? .easeInOut(duration: Timing.errorShakeUnit)
                                .repeatCount(Timing.errorShakeRepeat, autoreverses: true)
                            : .default,
                        value: errorShake
                    )
                    .scaleEffect(1.1) // slightly larger on the big screen
                    .padding(.bottom, 72)
            }
            .frame(maxWidth: .infinity)
        }
        .ignoresSafeArea()
    }

    private func triggerErrorShake() {
        errorShake = true
        DispatchQueue.main.asyncAfter(deadline: .now() + 0.4) { errorShake = false }
    }
}

// MARK: - Countdown Ring View

struct CountdownRingView: View {
    @ObservedObject var cleaningState: CleaningStateManager

    private var progress: Double {
        let total = Double(cleaningState.autoUnlockTimeout.rawValue)
        guard total > 0 else { return 0 }
        return max(0, 1.0 - Double(cleaningState.elapsedSeconds) / total)
    }

    var body: some View {
        VStack(spacing: 18) {
            ZStack {
                // Ambient glow
                Circle()
                    .fill(RadialGradient(
                        colors: [Color(red: 0.3, green: 0.55, blue: 1.0).opacity(0.14), .clear],
                        center: .center, startRadius: 0, endRadius: 120))
                    .frame(width: 250, height: 250)
                    .blur(radius: 28)

                // Track ring
                Circle()
                    .stroke(.primary.opacity(0.08), lineWidth: 5)
                    .frame(width: 200, height: 200)

                // Progress arc — blue to indigo, matches liquid glass palette
                Circle()
                    .trim(from: 0, to: progress)
                    .stroke(
                        LinearGradient(
                            colors: [Color(red: 0.4, green: 0.72, blue: 1.0),
                                     Color(red: 0.55, green: 0.32, blue: 0.98)],
                            startPoint: .topLeading, endPoint: .bottomTrailing),
                        style: StrokeStyle(lineWidth: 5, lineCap: .round))
                    .frame(width: 200, height: 200)
                    .rotationEffect(.degrees(-90))
                    .animation(.linear(duration: 1), value: progress)

                // Center: remaining time
                VStack(spacing: 3) {
                    Text(cleaningState.remainingTimeString ?? "")
                        .font(.system(size: 46, weight: .thin).monospacedDigit())
                        .foregroundStyle(.primary)
                        .contentTransition(.numericText(countsDown: true))
                        .animation(.easeInOut(duration: 0.35), value: cleaningState.elapsedSeconds)
                        .accessibilityLabel(
                            cleaningState.remainingTimeString.map { "Auto-unlock in \($0)" } ?? "")

                    Text("remaining")
                        .font(.system(size: 11, weight: .regular, design: .rounded))
                        .foregroundStyle(.secondary)
                        .accessibilityHidden(true)
                }
            }

            // Elapsed — secondary info below the ring
            HStack(spacing: 5) {
                Image(systemName: "clock")
                    .font(.system(size: 10))
                    .foregroundStyle(.tertiary)
                    .accessibilityHidden(true)
                Text("Locked for \(cleaningState.elapsedTimeString)")
                    .font(.system(size: 12, weight: .regular).monospacedDigit())
                    .foregroundStyle(.tertiary)
            }
            .accessibilityLabel("Locked for \(cleaningState.elapsedTimeString)")
        }
    }
}

// MARK: - Overlay Elapsed View (when auto-unlock is off)

struct OverlayElapsedView: View {
    @ObservedObject var cleaningState: CleaningStateManager

    var body: some View {
        VStack(spacing: 8) {
            Text(cleaningState.elapsedTimeString)
                .font(.system(size: 80, weight: .ultraLight).monospacedDigit())
                .foregroundStyle(.primary)
                .contentTransition(.numericText())
                .animation(.easeInOut(duration: 0.3), value: cleaningState.elapsedSeconds)
                .accessibilityLabel("Locked for \(cleaningState.elapsedTimeString)")

            Text("keyboard locked")
                .font(.system(size: 13, weight: .regular, design: .rounded))
                .foregroundStyle(.secondary)
                .accessibilityHidden(true)
        }
    }
}

// MARK: - Animation Extension

extension Animation {
    func repeatWhile(_ condition: Bool, autoreverses: Bool = true) -> Animation {
        condition ? repeatForever(autoreverses: autoreverses) : self
    }
}
