import SwiftUI

// MARK: - Animation Constants

private enum Timing {
    static let pulse: Double = 2.5
    static let background: Double = 12.0
    static let errorShakeUnit: Double = 0.06
    static let errorShakeRepeat = 6
}

// MARK: - Root View

struct ContentView: View {
    @EnvironmentObject private var cleaningState: CleaningStateManager

    var body: some View {
        ZStack {
            AnimatedBackgroundView()

            VStack(spacing: 0) {
                if cleaningState.isLocked {
                    LockedView(cleaningState: cleaningState)
                        .transition(.asymmetric(
                            insertion: .scale(scale: 0.95).combined(with: .opacity),
                            removal: .scale(scale: 1.05).combined(with: .opacity)
                        ))
                } else {
                    IdleView(cleaningState: cleaningState)
                        .transition(.asymmetric(
                            insertion: .scale(scale: 0.95).combined(with: .opacity),
                            removal: .scale(scale: 1.05).combined(with: .opacity)
                        ))
                }
            }
        }
        .frame(width: 480, height: 560)
        .ignoresSafeArea()
        .animation(.spring(response: 0.5, dampingFraction: 0.8), value: cleaningState.isLocked)
    }
}

// MARK: - Idle / Home Screen

struct IdleView: View {
    @ObservedObject var cleaningState: CleaningStateManager

    var body: some View {
        VStack(spacing: 24) {
            Spacer()

            // Icon + title
            VStack(spacing: 16) {
                ZStack {
                    Circle()
                        .fill(.ultraThinMaterial)
                        .frame(width: 100, height: 100)
                        .overlay(
                            Circle()
                                .stroke(
                                    LinearGradient(
                                        colors: [.white.opacity(0.6), .white.opacity(0.1)],
                                        startPoint: .topLeading,
                                        endPoint: .bottomTrailing
                                    ),
                                    lineWidth: 1
                                )
                        )
                        .shadow(color: .black.opacity(0.12), radius: 24, y: 8)

                    Image(systemName: "keyboard")
                        .font(.system(size: 40, weight: .light))
                        .foregroundStyle(
                            LinearGradient(
                                colors: [.white, .white.opacity(0.7)],
                                startPoint: .top,
                                endPoint: .bottom
                            )
                        )
                        .accessibilityHidden(true)
                }

                VStack(spacing: 6) {
                    Text("Keyboard Cleaner")
                        .font(.system(size: 28, weight: .semibold, design: .rounded))
                        .foregroundStyle(.white)
                        .accessibilityAddTraits(.isHeader)

                    Text("Lock your keyboard to clean safely")
                        .font(.system(size: 15, weight: .regular, design: .rounded))
                        .foregroundStyle(.white.opacity(0.7))
                        .multilineTextAlignment(.center)
                }
            }

            // Info cards
            VStack(spacing: 10) {
                InfoCardRow(
                    icon: "hand.raised.slash",
                    title: "Blocks all keystrokes",
                    subtitle: "No accidental input while cleaning"
                )
                InfoCardRow(
                    icon: "touchid",
                    title: "Touch ID to unlock",
                    subtitle: "Safe & secure, can't unlock by mistake"
                )
                InfoCardRow(
                    icon: "sparkles",
                    title: "Wipe with confidence",
                    subtitle: "Clean every key thoroughly"
                )
            }
            .padding(.horizontal, 32)

            // Auto-unlock picker
            AutoUnlockPickerRow(cleaningState: cleaningState)
                .padding(.horizontal, 32)

            Spacer()

            // Lock button
            Button {
                cleaningState.startCleaning()
            } label: {
                HStack(spacing: 10) {
                    Image(systemName: "lock.fill")
                        .font(.system(size: 16, weight: .semibold))
                        .accessibilityHidden(true)
                    Text("Lock Keyboard")
                        .font(.system(size: 17, weight: .semibold, design: .rounded))
                }
                .foregroundStyle(.white)
                .frame(maxWidth: .infinity)
                .frame(height: 52)
                .background(GlassButtonBackground())
                .shadow(color: .black.opacity(0.15), radius: 12, y: 4)
            }
            .buttonStyle(.plain)
            .padding(.horizontal, 32)
            .accessibilityLabel("Lock keyboard for cleaning")
            .accessibilityHint("Blocks all keyboard input. Use Touch ID to unlock when done.")

            Text("Requires Touch ID to unlock")
                .font(.system(size: 12, weight: .regular, design: .rounded))
                .foregroundStyle(.white.opacity(0.4))
                .padding(.bottom, 24)
        }
    }
}

// MARK: - Auto-Unlock Picker Row

struct AutoUnlockPickerRow: View {
    @ObservedObject var cleaningState: CleaningStateManager

    var body: some View {
        HStack(spacing: 12) {
            Image(systemName: "timer")
                .font(.system(size: 14, weight: .medium))
                .foregroundStyle(.white.opacity(0.6))
                .accessibilityHidden(true)

            Text("Auto-unlock")
                .font(.system(size: 13, weight: .medium, design: .rounded))
                .foregroundStyle(.white.opacity(0.6))
                .accessibilityHidden(true)

            Spacer()

            Picker("Auto-unlock after", selection: $cleaningState.autoUnlockTimeout) {
                ForEach(AutoUnlockTimeout.allCases) { option in
                    Text(option.label).tag(option)
                }
            }
            .pickerStyle(.segmented)
            .frame(width: 210)
            .colorScheme(.dark)
            .accessibilityHint("Set a duration after which the keyboard unlocks automatically")
        }
    }
}

// MARK: - Info Card Row

struct InfoCardRow: View {
    let icon: String
    let title: String
    let subtitle: String

    var body: some View {
        HStack(spacing: 16) {
            ZStack {
                RoundedRectangle(cornerRadius: 10)
                    .fill(.ultraThinMaterial)
                    .frame(width: 40, height: 40)
                    .overlay(
                        RoundedRectangle(cornerRadius: 10)
                            .stroke(.white.opacity(0.2), lineWidth: 0.5)
                    )
                Image(systemName: icon)
                    .font(.system(size: 17, weight: .medium))
                    .foregroundStyle(.white.opacity(0.85))
                    .accessibilityHidden(true)
            }

            VStack(alignment: .leading, spacing: 2) {
                Text(title)
                    .font(.system(size: 14, weight: .semibold, design: .rounded))
                    .foregroundStyle(.white.opacity(0.9))
                Text(subtitle)
                    .font(.system(size: 12, weight: .regular, design: .rounded))
                    .foregroundStyle(.white.opacity(0.5))
            }

            Spacer()
        }
        .padding(.horizontal, 16)
        .padding(.vertical, 12)
        .background(
            RoundedRectangle(cornerRadius: 14)
                .fill(.ultraThinMaterial)
                .overlay(
                    RoundedRectangle(cornerRadius: 14)
                        .stroke(.white.opacity(0.15), lineWidth: 0.5)
                )
        )
        .accessibilityElement(children: .combine)
        .accessibilityLabel("\(title). \(subtitle)")
    }
}

// MARK: - Locked View (in-app fallback, shown behind the overlay)

struct LockedView: View {
    @ObservedObject var cleaningState: CleaningStateManager
    @State private var pulseAnimation = false
    @State private var errorShake = false

    var body: some View {
        VStack(spacing: 0) {
            if cleaningState.accessibilityDenied {
                AccessibilityWarningBanner()
                    .padding(.horizontal, 24)
                    .padding(.top, 20)
                    .transition(.move(edge: .top).combined(with: .opacity))
            }

            Spacer()

            VStack(spacing: 24) {
                ZStack {
                    ForEach(0..<3) { index in
                        Circle()
                            .stroke(.white.opacity(0.08 - Double(index) * 0.02), lineWidth: 1)
                            .frame(
                                width: CGFloat(140 + index * 36),
                                height: CGFloat(140 + index * 36)
                            )
                            .scaleEffect(pulseAnimation ? 1.08 : 1.0)
                            .animation(
                                .easeInOut(duration: Timing.pulse)
                                    .repeatForever(autoreverses: true)
                                    .delay(Double(index) * 0.3),
                                value: pulseAnimation
                            )
                    }

                    Circle()
                        .fill(.ultraThinMaterial)
                        .frame(width: 120, height: 120)
                        .overlay(
                            Circle()
                                .stroke(
                                    LinearGradient(
                                        colors: [.white.opacity(0.5), .white.opacity(0.05)],
                                        startPoint: .topLeading,
                                        endPoint: .bottomTrailing
                                    ),
                                    lineWidth: 1.5
                                )
                        )
                        .shadow(color: .black.opacity(0.2), radius: 30, y: 10)

                    Image(systemName: "lock.fill")
                        .font(.system(size: 44, weight: .light))
                        .foregroundStyle(.white.opacity(0.9))
                        .accessibilityHidden(true)
                }
                .offset(x: errorShake ? -8 : 0)
                .animation(
                    errorShake
                        ? .easeInOut(duration: Timing.errorShakeUnit)
                            .repeatCount(Timing.errorShakeRepeat, autoreverses: true)
                        : .default,
                    value: errorShake
                )
                .onAppear { pulseAnimation = true }

                VStack(spacing: 8) {
                    Text("Keyboard Locked")
                        .font(.system(size: 26, weight: .semibold, design: .rounded))
                        .foregroundStyle(.white)
                        .accessibilityAddTraits(.isHeader)

                    Text(statusMessage)
                        .font(.system(size: 14, weight: .regular, design: .rounded))
                        .foregroundStyle(.white.opacity(0.6))
                        .multilineTextAlignment(.center)
                        .frame(maxWidth: 280)
                        .animation(.easeInOut, value: cleaningState.authState)

                    if cleaningState.authState == .idle || cleaningState.authState == .failed {
                        TimerDisplay(cleaningState: cleaningState)
                            .padding(.top, 4)
                    }
                }
            }

            Spacer()

            Button {
                cleaningState.authenticateToUnlock { success in
                    if !success { triggerErrorShake() }
                }
            } label: {
                VStack(spacing: 10) {
                    ZStack {
                        Circle()
                            .fill(.ultraThinMaterial)
                            .frame(width: 64, height: 64)
                            .overlay(
                                Circle()
                                    .stroke(
                                        LinearGradient(
                                            colors: [
                                                authButtonColor.opacity(0.7),
                                                authButtonColor.opacity(0.2)
                                            ],
                                            startPoint: .topLeading,
                                            endPoint: .bottomTrailing
                                        ),
                                        lineWidth: 1.5
                                    )
                            )
                            .shadow(color: authButtonColor.opacity(0.3), radius: 16, y: 4)

                        Image(systemName: authIcon)
                            .font(.system(size: 28, weight: .light))
                            .foregroundStyle(authButtonColor)
                            .accessibilityHidden(true)
                    }
                    .scaleEffect(cleaningState.authState == .authenticating ? 1.05 : 1.0)
                    .animation(
                        .easeInOut(duration: 0.8).repeatWhile(
                            cleaningState.authState == .authenticating,
                            autoreverses: true
                        ),
                        value: cleaningState.authState
                    )

                    Text(authButtonLabel)
                        .font(.system(size: 13, weight: .medium, design: .rounded))
                        .foregroundStyle(.white.opacity(0.7))
                }
            }
            .buttonStyle(.plain)
            .disabled(cleaningState.authState == .authenticating || cleaningState.authState == .success)
            .accessibilityLabel(authButtonLabel)
            .accessibilityHint(cleaningState.authState == .idle ? "Uses Touch ID to safely unlock the keyboard" : "")
            .padding(.bottom, 48)
        }
        .frame(maxWidth: .infinity)
    }

    private var statusMessage: String {
        switch cleaningState.authState {
        case .idle:           return "All keystrokes are blocked.\nClean your keyboard freely."
        case .authenticating: return "Place your finger on Touch ID…"
        case .failed:         return "Touch ID failed. Please try again."
        case .success:        return "Unlocked successfully!"
        }
    }

    private var authIcon: String {
        switch cleaningState.authState {
        case .idle, .authenticating: return "touchid"
        case .failed:                return "arrow.clockwise"
        case .success:               return "checkmark.circle"
        }
    }

    private var authButtonLabel: String {
        switch cleaningState.authState {
        case .idle:           return "Unlock with Touch ID"
        case .authenticating: return "Verifying…"
        case .failed:         return "Try Again"
        case .success:        return "Unlocked"
        }
    }

    private var authButtonColor: Color {
        switch cleaningState.authState {
        case .failed:         return Color(red: 1.0, green: 0.4, blue: 0.4)
        case .authenticating: return Color(red: 0.6, green: 0.8, blue: 1.0)
        case .success:        return Color(red: 0.4, green: 0.9, blue: 0.6)
        default:              return .white
        }
    }

    private func triggerErrorShake() {
        errorShake = true
        DispatchQueue.main.asyncAfter(deadline: .now() + 0.4) { errorShake = false }
    }
}

// MARK: - Timer Display (compact, used in LockedView)

struct TimerDisplay: View {
    @ObservedObject var cleaningState: CleaningStateManager

    var body: some View {
        HStack(spacing: 16) {
            Label {
                Text(cleaningState.elapsedTimeString)
                    .font(.system(size: 13, weight: .medium, design: .monospaced))
                    .foregroundStyle(.white.opacity(0.5))
            } icon: {
                Image(systemName: "clock")
                    .font(.system(size: 11))
                    .foregroundStyle(.white.opacity(0.4))
            }
            .accessibilityLabel("Locked for \(cleaningState.elapsedTimeString)")

            if let remaining = cleaningState.remainingTimeString {
                Label {
                    Text(remaining)
                        .font(.system(size: 13, weight: .medium, design: .monospaced))
                        .foregroundStyle(.white.opacity(0.5))
                } icon: {
                    Image(systemName: "timer")
                        .font(.system(size: 11))
                        .foregroundStyle(.white.opacity(0.4))
                }
                .accessibilityLabel("Auto-unlock in \(remaining)")
            }
        }
    }
}

// MARK: - Accessibility Warning Banner

struct AccessibilityWarningBanner: View {
    var body: some View {
        HStack(spacing: 10) {
            Image(systemName: "exclamationmark.triangle.fill")
                .font(.system(size: 14, weight: .medium))
                .foregroundStyle(.orange)
                .accessibilityHidden(true)

            VStack(alignment: .leading, spacing: 2) {
                Text("Keyboard not fully blocked")
                    .font(.system(size: 13, weight: .semibold, design: .rounded))
                    .foregroundStyle(.white.opacity(0.9))
                Text("Grant Accessibility access in System Settings")
                    .font(.system(size: 11, weight: .regular, design: .rounded))
                    .foregroundStyle(.white.opacity(0.6))
            }

            Spacer()
        }
        .padding(.horizontal, 14)
        .padding(.vertical, 10)
        .background(
            RoundedRectangle(cornerRadius: 12)
                .fill(Color.orange.opacity(0.15))
                .overlay(
                    RoundedRectangle(cornerRadius: 12)
                        .stroke(Color.orange.opacity(0.4), lineWidth: 1)
                )
        )
        .accessibilityElement(children: .combine)
        .accessibilityLabel("Warning: Keyboard is not fully blocked. Grant Accessibility access in System Settings.")
    }
}

// MARK: - Glass Button Background

struct GlassButtonBackground: View {
    var body: some View {
        ZStack {
            RoundedRectangle(cornerRadius: 16).fill(.ultraThinMaterial)
            RoundedRectangle(cornerRadius: 16)
                .fill(LinearGradient(
                    colors: [.white.opacity(0.25), .white.opacity(0.08)],
                    startPoint: .top, endPoint: .bottom
                ))
            RoundedRectangle(cornerRadius: 16)
                .stroke(LinearGradient(
                    colors: [.white.opacity(0.5), .white.opacity(0.1)],
                    startPoint: .topLeading, endPoint: .bottomTrailing
                ), lineWidth: 1)
        }
    }
}

// MARK: - Menu Bar View

struct MenuBarView: View {
    @EnvironmentObject var cleaningState: CleaningStateManager

    var body: some View {
        if cleaningState.isLocked {
            Text("Locked for \(cleaningState.elapsedTimeString)")
                .foregroundStyle(.secondary)
            if let remaining = cleaningState.remainingTimeString {
                Text("Auto-unlock in \(remaining)")
                    .foregroundStyle(.secondary)
            }
            Divider()
            Button("Unlock Keyboard…") {
                cleaningState.authenticateToUnlock { _ in }
            }
        } else {
            Button("Lock Keyboard") {
                cleaningState.startCleaning()
            }
        }
        Divider()
        Button("Quit Keyboard Cleaner") {
            NSApplication.shared.terminate(nil)
        }
    }
}

// MARK: - Animated Background

struct AnimatedBackgroundView: View {
    @State private var animationPhase: CGFloat = 0

    var body: some View {
        ZStack {
            Rectangle()
                .fill(LinearGradient(
                    colors: [
                        Color(red: 0.05, green: 0.06, blue: 0.12),
                        Color(red: 0.07, green: 0.08, blue: 0.16)
                    ],
                    startPoint: .topLeading, endPoint: .bottomTrailing
                ))

            Ellipse()
                .fill(RadialGradient(
                    colors: [Color(red: 0.2, green: 0.35, blue: 0.9).opacity(0.35), .clear],
                    center: .center, startRadius: 0, endRadius: 200
                ))
                .frame(width: 380, height: 280)
                .offset(x: -60 + sin(animationPhase) * 20, y: -80 + cos(animationPhase * 0.7) * 15)
                .blur(radius: 40)

            Ellipse()
                .fill(RadialGradient(
                    colors: [Color(red: 0.5, green: 0.2, blue: 0.85).opacity(0.25), .clear],
                    center: .center, startRadius: 0, endRadius: 180
                ))
                .frame(width: 300, height: 300)
                .offset(x: 80 + cos(animationPhase * 0.8) * 25, y: 100 + sin(animationPhase * 1.1) * 20)
                .blur(radius: 50)

            Ellipse()
                .fill(RadialGradient(
                    colors: [Color(red: 0.1, green: 0.7, blue: 0.85).opacity(0.15), .clear],
                    center: .center, startRadius: 0, endRadius: 140
                ))
                .frame(width: 260, height: 200)
                .offset(x: 20 + sin(animationPhase * 1.3) * 30, y: -120 + cos(animationPhase * 0.9) * 25)
                .blur(radius: 35)
        }
        .ignoresSafeArea()
        .onAppear {
            withAnimation(.linear(duration: Timing.background).repeatForever(autoreverses: false)) {
                animationPhase = .pi * 2
            }
        }
    }
}

// MARK: - Animation Extension

extension Animation {
    func repeatWhile(_ condition: Bool, autoreverses: Bool = true) -> Animation {
        condition ? repeatForever(autoreverses: autoreverses) : self
    }
}

// MARK: - Overlay View (full-screen lock screen shown on all displays)

struct OverlayView: View {
    @ObservedObject var cleaningState: CleaningStateManager
    @State private var pulseAnimation = false
    @State private var errorShake = false

    var body: some View {
        ZStack {
            AnimatedBackgroundView()

            VStack(spacing: 0) {
                Spacer()

                // Lock orb
                lockOrb
                    .padding(.bottom, 32)

                // Title
                VStack(spacing: 10) {
                    Text("Keyboard Locked")
                        .font(.system(size: 34, weight: .semibold, design: .rounded))
                        .foregroundStyle(.white)
                        .accessibilityAddTraits(.isHeader)

                    Text(cleaningState.accessibilityDenied
                         ? "Keystrokes may not be blocked — grant Accessibility access in System Settings"
                         : "All keystrokes are blocked — clean your keyboard freely")
                        .font(.system(size: 15, weight: .regular, design: .rounded))
                        .foregroundStyle(cleaningState.accessibilityDenied
                            ? Color.orange.opacity(0.85)
                            : .white.opacity(0.5))
                        .multilineTextAlignment(.center)
                        .frame(maxWidth: 480)
                        .animation(.easeInOut, value: cleaningState.accessibilityDenied)
                }
                .padding(.bottom, 56)

                // Hero timer section
                if cleaningState.autoUnlockTimeout != .never {
                    CountdownRingView(cleaningState: cleaningState)
                } else {
                    OverlayElapsedView(
                        timeString: cleaningState.elapsedTimeString,
                        elapsedSeconds: cleaningState.elapsedSeconds
                    )
                }

                Spacer()

                // Unlock button
                overlayUnlockButton
                    .offset(x: errorShake ? -8 : 0)
                    .animation(
                        errorShake
                            ? .easeInOut(duration: Timing.errorShakeUnit)
                                .repeatCount(Timing.errorShakeRepeat, autoreverses: true)
                            : .default,
                        value: errorShake
                    )
                    .padding(.bottom, 72)
            }
            .frame(maxWidth: .infinity)
        }
        .ignoresSafeArea()
    }

    // MARK: Lock Orb

    private var lockOrb: some View {
        ZStack {
            ForEach(0..<3) { i in
                Circle()
                    .stroke(.white.opacity(max(0, 0.07 - Double(i) * 0.02)), lineWidth: 1)
                    .frame(width: CGFloat(160 + i * 44), height: CGFloat(160 + i * 44))
                    .scaleEffect(pulseAnimation ? 1.08 : 1.0)
                    .animation(
                        .easeInOut(duration: Timing.pulse)
                            .repeatForever(autoreverses: true)
                            .delay(Double(i) * 0.35),
                        value: pulseAnimation
                    )
            }

            // Glass orb
            Circle()
                .fill(.ultraThinMaterial)
                .frame(width: 136, height: 136)
                .overlay(
                    Circle()
                        .stroke(
                            LinearGradient(
                                colors: [.white.opacity(0.55), .white.opacity(0.05)],
                                startPoint: .topLeading,
                                endPoint: .bottomTrailing
                            ),
                            lineWidth: 1.5
                        )
                )
                .shadow(color: .black.opacity(0.3), radius: 48, y: 16)

            Image(systemName: "lock.fill")
                .font(.system(size: 52, weight: .light))
                .foregroundStyle(.white.opacity(0.9))
                .accessibilityHidden(true)
        }
        .onAppear { pulseAnimation = true }
        .accessibilityLabel("Keyboard is locked")
    }

    // MARK: Unlock Button

    private var overlayUnlockButton: some View {
        Button {
            cleaningState.authenticateToUnlock { success in
                if !success { triggerErrorShake() }
            }
        } label: {
            VStack(spacing: 14) {
                ZStack {
                    // Glow
                    Circle()
                        .fill(authColor.opacity(0.15))
                        .frame(width: 88, height: 88)
                        .blur(radius: 16)

                    Circle()
                        .fill(.ultraThinMaterial)
                        .frame(width: 72, height: 72)
                        .overlay(
                            Circle()
                                .stroke(
                                    LinearGradient(
                                        colors: [authColor.opacity(0.8), authColor.opacity(0.15)],
                                        startPoint: .topLeading,
                                        endPoint: .bottomTrailing
                                    ),
                                    lineWidth: 1.5
                                )
                        )
                        .shadow(color: authColor.opacity(0.35), radius: 24, y: 8)

                    Image(systemName: authIcon)
                        .font(.system(size: 30, weight: .light))
                        .foregroundStyle(authColor)
                        .accessibilityHidden(true)
                }
                .scaleEffect(cleaningState.authState == .authenticating ? 1.06 : 1.0)
                .animation(
                    .easeInOut(duration: 0.8).repeatWhile(
                        cleaningState.authState == .authenticating,
                        autoreverses: true
                    ),
                    value: cleaningState.authState
                )

                Text(authLabel)
                    .font(.system(size: 15, weight: .medium, design: .rounded))
                    .foregroundStyle(.white.opacity(0.6))
            }
        }
        .buttonStyle(.plain)
        .disabled(cleaningState.authState == .authenticating || cleaningState.authState == .success)
        .accessibilityLabel(authLabel)
        .accessibilityHint(cleaningState.authState == .idle ? "Authenticates with Touch ID to unlock the keyboard" : "")
    }

    private var authIcon: String {
        switch cleaningState.authState {
        case .idle, .authenticating: return "touchid"
        case .failed:                return "arrow.clockwise"
        case .success:               return "checkmark.circle"
        }
    }

    private var authLabel: String {
        switch cleaningState.authState {
        case .idle:           return "Unlock with Touch ID"
        case .authenticating: return "Verifying…"
        case .failed:         return "Try Again"
        case .success:        return "Unlocked"
        }
    }

    private var authColor: Color {
        switch cleaningState.authState {
        case .failed:         return Color(red: 1.0, green: 0.4, blue: 0.4)
        case .authenticating: return Color(red: 0.6, green: 0.8, blue: 1.0)
        case .success:        return Color(red: 0.4, green: 0.9, blue: 0.6)
        default:              return .white
        }
    }

    private func triggerErrorShake() {
        errorShake = true
        DispatchQueue.main.asyncAfter(deadline: .now() + 0.4) { errorShake = false }
    }
}

// MARK: - Countdown Ring View

struct CountdownRingView: View {
    @ObservedObject var cleaningState: CleaningStateManager

    private var progress: Double {
        let total = Double(cleaningState.autoUnlockTimeout.rawValue)
        guard total > 0 else { return 0 }
        return max(0, 1.0 - Double(cleaningState.elapsedSeconds) / total)
    }

    var body: some View {
        VStack(spacing: 20) {
            ZStack {
                // Ambient glow behind the ring
                Circle()
                    .fill(RadialGradient(
                        colors: [Color(red: 0.35, green: 0.55, blue: 1.0).opacity(0.2), .clear],
                        center: .center, startRadius: 0, endRadius: 130
                    ))
                    .frame(width: 260, height: 260)
                    .blur(radius: 30)

                // Track
                Circle()
                    .stroke(.white.opacity(0.07), lineWidth: 6)
                    .frame(width: 200, height: 200)

                // Progress arc
                Circle()
                    .trim(from: 0, to: progress)
                    .stroke(
                        LinearGradient(
                            colors: [
                                Color(red: 0.35, green: 0.75, blue: 1.0),
                                Color(red: 0.6, green: 0.35, blue: 1.0)
                            ],
                            startPoint: .topLeading,
                            endPoint: .bottomTrailing
                        ),
                        style: StrokeStyle(lineWidth: 6, lineCap: .round)
                    )
                    .frame(width: 200, height: 200)
                    .rotationEffect(.degrees(-90))
                    .animation(.linear(duration: 1), value: progress)

                // Center content
                VStack(spacing: 4) {
                    Text(cleaningState.remainingTimeString ?? "")
                        .font(.system(size: 48, weight: .thin, design: .monospaced))
                        .foregroundStyle(.white)
                        .contentTransition(.numericText(countsDown: true))
                        .animation(.easeInOut(duration: 0.4), value: cleaningState.elapsedSeconds)
                        .accessibilityLabel(cleaningState.remainingTimeString.map { "Auto-unlock in \($0)" } ?? "")

                    Text("remaining")
                        .font(.system(size: 12, weight: .regular, design: .rounded))
                        .foregroundStyle(.white.opacity(0.35))
                        .accessibilityHidden(true)
                }
            }

            // Elapsed time — subtle, below the ring
            HStack(spacing: 6) {
                Image(systemName: "clock")
                    .font(.system(size: 11))
                    .foregroundStyle(.white.opacity(0.28))
                    .accessibilityHidden(true)
                Text("Locked for \(cleaningState.elapsedTimeString)")
                    .font(.system(size: 12, weight: .regular, design: .rounded))
                    .foregroundStyle(.white.opacity(0.28))
            }
            .accessibilityLabel("Locked for \(cleaningState.elapsedTimeString)")
        }
    }
}

// MARK: - Overlay Elapsed View (shown when auto-unlock is off)

struct OverlayElapsedView: View {
    let timeString: String
    let elapsedSeconds: Int

    var body: some View {
        VStack(spacing: 10) {
            Text(timeString)
                .font(.system(size: 72, weight: .ultraLight, design: .monospaced))
                .foregroundStyle(.white.opacity(0.88))
                .contentTransition(.numericText())
                .animation(.easeInOut(duration: 0.3), value: elapsedSeconds)
                .accessibilityLabel("Locked for \(timeString)")

            Text("keyboard locked")
                .font(.system(size: 13, weight: .regular, design: .rounded))
                .foregroundStyle(.white.opacity(0.3))
                .accessibilityHidden(true)
        }
    }
}
